{
  "name": "@codex-sender/cli",
  "type": "module",
  "version": "0.2.0",
  "description": "为 Cursor Agent 输入框注入交接提示词到 Codex App 的按钮。",
  "author": {
    "name": "BINGWU2003",
    "url": "https://github.com/BINGWU2003"
  },
  "license": "MIT",
  "homepage": "https://github.com/BINGWU2003/codex-sender#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BINGWU2003/codex-sender.git",
    "directory": "packages/cli"
  },
  "bugs": "https://github.com/BINGWU2003/codex-sender/issues",
  "keywords": [
    "cursor",
    "codex",
    "cli",
    "developer-tools"
  ],
  "exports": {
    ".": "./dist/cli.mjs"
  },
  "bin": {
    "codex-sender": "./dist/cli.mjs"
  },
  "files": [
    "README.md",
    "dist"
  ],
  "engines": {
    "node": ">=20.12.0"
  },
  "os": [
    "win32"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "prepack": "pnpm --workspace-root turbo run build --filter=@codex-sender/cli...",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "catalog:"
  },
  "devDependencies": {
    "@codex-sender/bridge": "workspace:*",
    "@codex-sender/injector": "workspace:*",
    "@types/node": "catalog:types",
    "tsdown": "catalog:cli",
    "typescript": "catalog:cli",
    "vitest": "catalog:testing"
  }
}
