{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "运行 Codex Sender 扩展",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/apps/extension"
