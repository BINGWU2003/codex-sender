{
  "name": "@codex-sender/monorepo",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "description": "一个通过 npm CLI 为 Cursor 注入 Codex 发送按钮的本地工具。",
  "author": {
    "name": "BINGWU2003",
    "url": "https://github.com/BINGWU2003"
  },
  "license": "MIT",
  "homepage": "https://github.com/BINGWU2003/codex-sender#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BINGWU2003/codex-sender.git"
  },
  "bugs": "https://github.com/BINGWU2003/codex-sender/issues",
  "scripts": {
    "build": "turbo run build",
    "check": "pnpm run lint && turbo run typecheck test build",
    "dev": "turbo run dev",
    "lint": "eslint . && turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "prepare": "git config core.hooksPath .githooks && simple-git-hooks && skills-npm"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:cli",
    "eslint": "catalog:cli",
    "nano-staged": "catalog:cli",
    "simple-git-hooks": "catalog:cli",
    "skills-npm": "catalog:cli",
    "turbo": "catalog:cli",
    "typescript": "catalog:cli"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm install --frozen-lockfile --ignore-scripts --offline && pnpm run check && npx nano-staged"
  },
  "nano-staged": {
    "*.{js,cjs,mjs,ts,tsx,json,jsonc,yaml,yml,md}": "eslint --fix"
  }
}
