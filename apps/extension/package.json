{
  "publisher": "BINGWU2003",
  "name": "codex-sender",
  "displayName": "Codex Sender",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "description": "将 VS Code 与 Cursor 中的代码片段和问题发送到 Codex 任务。",
  "license": "MIT",
  "keywords": ["codex", "cursor", "ai", "developer-tools"],
  "categories": ["Other"],
  "main": "./dist/extension.cjs",
  "engines": {
    "vscode": "^1.100.0"
  },
  "activationEvents": [
    "onView:codexSender.panel",
    "onCommand:codexSender.addSelection",
    "onCommand:codexSender.openPanel"
  ],
  "contributes": {
    "commands": [
      {
        "command": "codexSender.openPanel",
        "title": "Codex Sender: 打开发送面板"
      },
      {
        "command": "codexSender.addSelection",
        "title": "Codex Sender: 添加当前代码选区"
      }
    ],
    "keybindings": [
      {
        "command": "codexSender.addSelection",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a",
        "when": "editorTextFocus && editorHasSelection"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codexSender",
          "title": "Codex Sender",
          "icon": "assets/codex-sender.svg"
        }
      ]
    },
    "views": {
      "codexSender": [
        {
          "type": "webview",
          "id": "codexSender.panel",
          "name": "发送到 Codex"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "pnpm run build"
  },
  "dependencies": {
    "@codex-sender/app-server-client": "workspace:*",
    "@codex-sender/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "@types/vscode": "catalog:types",
    "tsdown": "catalog:cli",
    "typescript": "catalog:cli",
    "vitest": "catalog:testing"
  }
}
